{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "status"],
    "properties": {
      "id": {
      "type": "integer"
    },
      "title": {
      "type": "string",
      "description": "The task title",
      "minLength": 1
    },
      "description": {
      "type": "string"
      },
      "status": {
      "type": "string",
      "enum": ["PENDING", "COMPLETED"]
      }
    }
  }
}